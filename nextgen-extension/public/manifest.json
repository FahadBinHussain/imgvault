{
  "manifest_version": 3,
  "name": "ImgVault",
  "version": "2.0.0",
  "description": "Next-generation image vault with context preservation and advanced duplicate detection",
  "author": "ImgVault Team",
  "key": "",
  
  "permissions": [
    "contextMenus",
    "activeTab",
    "tabs",
    "storage",
    "scripting",
    "nativeMessaging",
    "cookies",
    "downloads",
    "notifications",
    "declarativeNetRequest"
  ],
  
  "host_permissions": [
    "https://pixvid.org/*",
    "<all_urls>"
  ],
  
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  
  "action": {
    "default_icon": {
      "16": "icons/1.png",
      "32": "icons/1.png",
      "48": "icons/1.png",
      "128": "icons/1.png"
    },
    "default_title": "ImgVault - Open Gallery"
  },
  
  "icons": {
    "16": "icons/1.png",
    "32": "icons/1.png",
    "48": "icons/1.png",
    "128": "icons/1.png"
  },
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": ["*://*.flickr.com/*"],
      "js": ["content.js"],
      "css": ["flickr-fix.css"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["*://*.slideshare.net/*"],
      "js": ["content.js"],
      "css": ["slideshare-fix.css"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["*://*.rajce.idnes.cz/*"],
      "js": ["content.js"],
      "css": ["rajce-fix.css"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["https://open.spotify.com/*"],
      "js": ["contextmenu-unlock.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["https://www.behance.net/*", "https://behance.net/*"],
      "js": ["contextmenu-unlock.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["https://www.instagram.com/*", "https://instagram.com/*"],
      "js": ["contextmenu-unlock.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["https://www.skidrowreloaded.com/*", "https://skidrowreloaded.com/*"],
      "js": ["contextmenu-unlock.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  
  "web_accessible_resources": [
    {
      "resources": ["lib/*.js", "scene-viewer.html", "scene-viewer.js"],
      "matches": ["<all_urls>"]
    }
  ],
  
  "minimum_chrome_version": "93",
  
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
